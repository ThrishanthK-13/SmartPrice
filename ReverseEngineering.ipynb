import cv2
import numpy as np

img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

# ===== SIZE DETECTION =====
gray = cv2.cvtColor(img_rgb, cv2.COLOR_RGB2GRAY)
blur = cv2.GaussianBlur(gray, (7,7), 0)
edges = cv2.Canny(blur, 50, 150)

contours, _ = cv2.findContours(edges, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

if contours:
    c = max(contours, key=cv2.contourArea)
    area = cv2.contourArea(c)
else:
    area = img_rgb.shape[0] * img_rgb.shape[1]

# ===== RIPENESS DETECTION =====
hsv = cv2.cvtColor(img_rgb, cv2.COLOR_RGB2HSV)
v = hsv[:,:,2]

mask = edges > 0
avg_val = np.mean(v[mask]) if np.any(mask) else np.mean(v)

if avg_val < 90:
    ripeness = "unripe"
elif avg_val < 200:
    ripeness = "ripe"
else:
    ripeness = "overripe"

# ===== GET REAL MARKET PRICE (API) =====
base_price = get_market_price(fruit_name)

# ===== SIZE FACTOR (IMPROVED) =====
if area > 120000:
    size_factor = 1.4
elif area < 40000:
    size_factor = 0.7
else:
    size_factor = 1.0

# ===== RIPENESS FACTOR (STRONG EFFECT 🔥) =====
if ripeness == "unripe":
    ripeness_factor = 0.8
elif ripeness == "ripe":
    ripeness_factor = 2.0
else:
    ripeness_factor = 0.6

# ===== COLOR QUALITY BONUS =====
if color_name in ["Red", "Yellow"]:
    color_factor = 1.2
else:
    color_factor = 1.0

# ===== FINAL PRICE =====
final_price = base_price * size_factor * ripeness_factor * color_factor

