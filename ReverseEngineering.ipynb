import numpy as np

fruits = ['Apple', 'Banana', 'Orange', 'Mango', 'Guava']

ripe_prices = [120, 40, 60, 80, 50]
unripe_prices = [p * 0.9 for p in ripe_prices]
overripe_prices = [p * 0.7 for p in ripe_prices]

x = np.arange(len(fruits))
width = 0.25

plt.figure(figsize=(10,5))

plt.bar(x - width, unripe_prices, width, label='Unripe')
plt.bar(x, ripe_prices, width, label='Ripe')
plt.bar(x + width, overripe_prices, width, label='Overripe')

plt.xticks(x, fruits)
plt.xlabel("Fruit Type")
plt.ylabel("Price (₹)")
plt.title("Fruit Price Variation Based on Ripeness")
plt.legend()
plt.grid(True)

plt.show()
