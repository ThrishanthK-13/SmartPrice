import matplotlib.pyplot as plt
import numpy as np
from google.colab import files

# Brightness range
x = np.linspace(0, 255, 50)

# Piecewise + slight variation
y = []

for val in x:
    if val < 80:
        score = (val / 80) * 0.4
    elif val < 160:
        score = 0.4 + ((val - 80) / 80) * 0.6
    else:
        score = 1 - ((val - 160) / 95) * 0.5

    score += 0.05 * np.sin(val / 10)
    y.append(score)

y = np.clip(y, 0, 1)

plt.figure(figsize=(8,4))

# ✅ Line WITHOUT dots
plt.plot(x, y, linewidth=2)

# ✅ ONLY one dot (your input)
actual_score = y[np.argmin(abs(x - avg_val))]
plt.scatter(avg_val, actual_score, s=120)

plt.text(avg_val, actual_score, f'  {ripeness}', fontsize=10)

plt.title('Nonlinear Ripeness Variation Based on Brightness')
plt.xlabel('Brightness (V Channel)')
plt.ylabel('Ripeness Score')
plt.grid(True)

# Save & download
