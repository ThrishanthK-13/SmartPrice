def get_market_price(fruit_name):
    if df.empty:
        print("⚠️ No data")
        return 60

    fruit_name = fruit_name.lower()

    # Ensure column exists
    if 'Commodity' not in df.columns:
        print("❌ Commodity column missing")
        print("Available columns:", df.columns)
        return 60

    df['Commodity_clean'] = df['Commodity'].str.lower()

    filtered = df[df['Commodity_clean'].str.contains(fruit_name)]

    if len(filtered) > 0:
        return filtered['Modal Price'].mean()
    else:
        print("❌ No match found")
        return 60
